@model IEnumerable<CMS.Data.Entities.Product>
@{
    Layout = "_LayoutAdmin";
}

<h2 class="text-primary">DANH SÁCH SẢN PHẨM</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Tên sản phẩm</th>
            <th>Mô tả</th>
            <th>Giá</th>
            <th>Số lượng</th>
            <th>Hình ảnh</th>
            <th>Danh mục</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Price</td>
                <td>@item.StockQuantity</td>
                <td>@item.ImageUrl</td>
                <td>@item.CategoryProductId</td>
            </tr>
        }
    </tbody>
</table>